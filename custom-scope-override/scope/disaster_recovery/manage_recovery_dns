#!/bin/bash

SITE=$(echo "$CONTEXT" | jq -r '.scope.dimensions.site // "aws-main"')

# Build the recovery domain by prefixing "recovery-" onto the first DNS label
# of the scope domain, then re-truncating so that label stays within the 63-char
# DNS limit (mirrors the len-57 truncation logic in networking/dns/domain/domain-generate).
# Must match the construction in generate_disaster_recovery_domain so the DNS
# record lines up with the registered recovery domain.
RECOVERY_LABEL_MAX_LENGTH=63

SCOPE_DOMAIN_FIRST_LABEL="${SCOPE_DOMAIN%%.*}"
SCOPE_DOMAIN_REST="${SCOPE_DOMAIN#*.}"

RECOVERY_LABEL="recovery-${SCOPE_DOMAIN_FIRST_LABEL}"
if [[ ${#RECOVERY_LABEL} -gt $RECOVERY_LABEL_MAX_LENGTH ]]; then
  RECOVERY_LABEL="${RECOVERY_LABEL:0:$RECOVERY_LABEL_MAX_LENGTH}"
fi
# Strip any trailing dashes/dots left by truncation so the label stays valid
RECOVERY_LABEL=$(echo "$RECOVERY_LABEL" | sed 's/[-.]*$//')

RECOVERY_DOMAIN="${RECOVERY_LABEL}.${SCOPE_DOMAIN_REST}"

if [[ "$SITE" != "aws-dr" ]]; then
  echo "ℹ️  Site dimension is '$SITE' (not 'aws-dr'). Skipping disaster recovery domain generation."
  return
fi

echo "🔍 Disaster recovery scope detected (site: $SITE). Creating dns record: $RECOVERY_DOMAIN..."

MAIN_DOMAIN="$SCOPE_DOMAIN"
SCOPE_DOMAIN="$RECOVERY_DOMAIN"

export SCOPE_DOMAIN

source "$SERVICE_PATH/scope/networking/dns/manage_dns"

echo "✅ Recovery dns created: $RECOVERY_DOMAIN"

SCOPE_DOMAIN="$MAIN_DOMAIN"

export SCOPE_DOMAIN