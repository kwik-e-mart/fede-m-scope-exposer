#!/bin/bash

SITE=$(echo "$CONTEXT" | jq -r '.scope.dimensions.site // "aws-main"')

if [[ "$SITE" != "aws-dr" ]]; then
  echo "ℹ️  Site dimension is '$SITE' (not 'aws-dr'). Skipping disaster recovery domain generation."
  return
fi

echo "🔍 Disaster recovery scope detected (site: $SITE). Resolving main domain..."

RECOVERY_SCOPE_SUFFIX=${RECOVERY_SCOPE_SUFFIX:-"recovery"}

SCOPE_SLUG=$(echo "$CONTEXT" | jq -r '.scope.slug')
MAIN_SCOPE_SLUG="${SCOPE_SLUG%-"$RECOVERY_SCOPE_SUFFIX"}"

# Scope slugs are immutable, but a scope's display name can change after creation.
# Derive the main scope name from the DR scope name by stripping the recovery
# suffix (tolerating a dash or space separator, case-insensitive) so we can fall
# back to a name match when the immutable slug no longer lines up (renamed scope).
SCOPE_NAME=$(echo "$CONTEXT" | jq -r '.scope.name // empty')
MAIN_SCOPE_NAME="$SCOPE_NAME"
if [[ -n "$SCOPE_NAME" ]]; then
  shopt -s nocasematch
  if [[ "$SCOPE_NAME" =~ ^(.*[^[:space:]-])[[:space:]-]+"$RECOVERY_SCOPE_SUFFIX"$ ]]; then
    MAIN_SCOPE_NAME="${BASH_REMATCH[1]}"
  fi
  shopt -u nocasematch
fi

APPLICATION_ID=$(echo "$CONTEXT" | jq -r '.application.id')
SCOPE_ID=$(echo "$CONTEXT" | jq -r '.scope.id')

echo "📋 DR scope: $SCOPE_SLUG (id: $SCOPE_ID) | Main scope slug: $MAIN_SCOPE_SLUG | Main scope name: $MAIN_SCOPE_NAME | Application: $APPLICATION_ID"

echo "📡 Looking up main scope '$MAIN_SCOPE_SLUG'..."
if ! MAIN_SCOPE=$(np scope list \
  --application_id "$APPLICATION_ID" \
  --status "active,stopped" \
  --format json 2>&1); then
  echo "❌ Failed to list scopes for application '$APPLICATION_ID'" >&2
  echo "💡 Possible causes:" >&2
  echo "   - The nullplatform CLI is not authenticated in this environment" >&2
  echo "   - The application id '$APPLICATION_ID' is incorrect" >&2
  echo "🔧 How to fix:" >&2
  echo "   - Verify CLI auth and retry: np scope list --application_id $APPLICATION_ID" >&2
  echo "   - CLI error: $MAIN_SCOPE" >&2
  exit 1
fi

# 1) Prefer an exact slug match: fast path, unaffected by display-name changes.
SCOPE_DOMAIN=$(echo "$MAIN_SCOPE" | jq -r --arg slug "$MAIN_SCOPE_SLUG" \
  'first(.results[] | select(.slug == $slug) | .domain) // empty')

# 2) Fall back to an exact name match. Covers main scopes renamed after creation,
#    whose immutable slug no longer matches the slug derived from the DR scope.
if [[ -z "$SCOPE_DOMAIN" && -n "$MAIN_SCOPE_NAME" ]]; then
  echo "ℹ️  No scope matched slug '$MAIN_SCOPE_SLUG'; trying exact name match '$MAIN_SCOPE_NAME'..."
  SCOPE_DOMAIN=$(echo "$MAIN_SCOPE" | jq -r --arg name "$MAIN_SCOPE_NAME" \
    'first(.results[] | select(.name == $name) | .domain) // empty')
fi

if [[ -z "$SCOPE_DOMAIN" ]]; then
  echo "❌ No main scope found for slug '$MAIN_SCOPE_SLUG' or name '$MAIN_SCOPE_NAME' (application: $APPLICATION_ID)" >&2
  echo "💡 Possible causes:" >&2
  echo "   - The main scope '$MAIN_SCOPE_SLUG' has not been created yet" >&2
  echo "   - A disaster recovery scope cannot exist without its main counterpart," >&2
  echo "     since it must inherit the main domain to take over traffic on failover" >&2
  echo "🔧 How to fix:" >&2
  echo "   - Create the main scope '$MAIN_SCOPE_SLUG' first, then create this recovery scope" >&2
  exit 1
fi

echo "✅ Main domain resolved: $SCOPE_DOMAIN"

echo "📝 Patching DR scope '$SCOPE_ID' with domain '$SCOPE_DOMAIN'..."
if ! np scope patch --id "$SCOPE_ID" --body "{\"domain\":\"$SCOPE_DOMAIN\"}"; then
  echo "❌ Failed to patch scope '$SCOPE_ID' with domain '$SCOPE_DOMAIN'" >&2
  echo "💡 Possible causes:" >&2
  echo "   - The scope id '$SCOPE_ID' is incorrect or the scope was deleted" >&2
  echo "   - The CLI lacks permissions to patch this scope" >&2
  echo "🔧 How to fix:" >&2
  echo "   - Verify the scope exists: np scope read --id $SCOPE_ID" >&2
  exit 1
fi

echo "✨ Disaster recovery scope '$SCOPE_SLUG' now serves domain '$SCOPE_DOMAIN'"

# Build the recovery domain by prefixing "recovery-" onto the first DNS label
# of the scope domain, then re-truncating so that label stays within the 63-char
# DNS limit (mirrors the len-57 truncation logic in networking/dns/domain/domain-generate).
RECOVERY_LABEL_MAX_LENGTH=63

SCOPE_DOMAIN_FIRST_LABEL="${SCOPE_DOMAIN%%.*}"
SCOPE_DOMAIN_REST="${SCOPE_DOMAIN#*.}"

RECOVERY_LABEL="recovery-${SCOPE_DOMAIN_FIRST_LABEL}"
if [[ ${#RECOVERY_LABEL} -gt $RECOVERY_LABEL_MAX_LENGTH ]]; then
  RECOVERY_LABEL="${RECOVERY_LABEL:0:$RECOVERY_LABEL_MAX_LENGTH}"
fi
# Strip any trailing dashes/dots left by truncation so the label stays valid
RECOVERY_LABEL=$(echo "$RECOVERY_LABEL" | sed 's/[-.]*$//')

RECOVERY_DOMAIN="${RECOVERY_LABEL}.${SCOPE_DOMAIN_REST}"

DOMAIN_BODY=$(jq -n \
  --argjson scope_id "$SCOPE_ID" \
  --arg name "$RECOVERY_DOMAIN" \
  '{scope_id: $scope_id, name: $name, type: "scope"}')

echo "🔍 Checking whether recovery domain '$RECOVERY_DOMAIN' already exists for scope '$SCOPE_ID'..."
if EXISTING_DOMAINS=$(np scope domain list --organization_id "$ORGANIZATION_ID" --scope_id "$SCOPE_ID" --name "$RECOVERY_DOMAIN" --format json 2>&1); then
  if echo "$EXISTING_DOMAINS" | jq -e --arg name "$RECOVERY_DOMAIN" \
    'any(.results[]?; .name == $name)' >/dev/null 2>&1; then
    echo "ℹ️  Recovery domain '$RECOVERY_DOMAIN' already exists for scope '$SCOPE_ID'. Skipping creation."
    export SCOPE_DOMAIN
    export RECOVERY_DOMAIN
    return
  fi
else
  echo "⚠️  Could not verify existing domains for scope '$SCOPE_ID'; will attempt creation anyway." >&2
  echo "   - CLI error: $EXISTING_DOMAINS" >&2
fi

echo "📝 Creating recovery domain '$RECOVERY_DOMAIN' for scope '$SCOPE_ID'..."
if ! np scope domain create --body "$DOMAIN_BODY"; then
  echo "❌ Failed to create recovery domain '$RECOVERY_DOMAIN' for scope '$SCOPE_ID'" >&2
  echo "💡 Possible causes:" >&2
  echo "   - A domain named '$RECOVERY_DOMAIN' may already exist for this (or other) scope" >&2
  echo "🔧 How to fix:" >&2
  echo "   - List existing domains: np scope domain list --all --organization_id $ORGANIZATION_ID" >&2
  exit 1
fi

echo "✅ Recovery domain '$RECOVERY_DOMAIN' created for scope '$SCOPE_ID'"

export SCOPE_DOMAIN
export RECOVERY_DOMAIN
